# Optional environment variables for local development / deployment

# Server: allowed CORS origin (default *)
# CLIENT_ORIGIN=http://localhost:5173

# Server: listen port (Render sets PORT automatically)
# PORT=3001

# Client: backend URL for Socket.IO (default http://<hostname>:3001)
# VITE_SERVER_URL=http://localhost:3001

# Supabase — database + storage (server only; use service_role key, never expose to client)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth — signed session cookie for user login (username + password, no email)
# AUTH_SESSION_SECRET=long-random-string-for-hmac

# One-time: creates username "admin" on first deploy if no admin exists yet
# ADMIN_BOOTSTRAP_PASSWORD=choose-a-strong-password

# Legacy (no longer used for login — kept for backwards compat during migration)
# ADMIN_PASSWORD=
# ADMIN_SESSION_SECRET=
